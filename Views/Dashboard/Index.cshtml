@model PilinutVendorSystem.Models.DashboardViewModel

@{
    ViewData["Title"] = "Dashboard";
}

<!-- Dashboard Header -->
<div class="page-header">
    <h1 class="page-title">Inventory Dashboard</h1>
    <p class="page-subtitle">Real-time overview of your pilinut products</p>
</div>

<!-- Metrics Grid -->
<div class="metrics-grid">
    <!-- Total Items -->
    <div class="metric-card">
        <div class="metric-info">
            <h6>Total Products</h6>
            <div id="totalItems" class="metric-value">
                <span>@Model.TotalItems</span>
                <span class="metric-icon">📦</span>
            </div>
        </div>
    </div>

    <!-- Available Stock -->
    <div class="metric-card">
        <div class="metric-info">
            <h6>Available Stock</h6>
            <div id="freshStock" class="metric-value">
                <span>@Model.FreshStock.ToString("F0")</span>
                <span class="metric-icon">📊</span>
            </div>
        </div>
    </div>

    <!-- Low Stock -->
    <div class="metric-card">
        <div class="metric-info">
            <h6>Low Stock Items</h6>
            <div id="lowStock" class="metric-value">
                <span>@Model.LowStockItems</span>
                <span class="metric-icon">⚠️</span>
            </div>
        </div>
    </div>

    <!-- Out of Stock -->
    <div class="metric-card">
        <div class="metric-info">
            <h6>Out of Stock</h6>
            <div id="spoiledItems" class="metric-value">
                <span>@Model.SpoiledItems</span>
                <span class="metric-icon">🚫</span>
            </div>
        </div>
    </div>
</div>

<!-- Recent Products -->
<div class="recent-section">
    <h2 class="section-title">Recent Products</h2>

    @if (Model.RecentItems.Any())
    {
        <table class="table">
            <thead>
                <tr>
                    <th>Product Name</th>
                    <th>Category</th>
                    <th>Quantity</th>
                    <th>Status</th>
                </tr>
            </thead>
            <tbody id="recentItemsTbody">
                @foreach (var item in Model.RecentItems)
                {
                    <tr>
                        <td>@item.Name</td>
                        <td>@item.Category</td>
                        <td id="qty_@item.Id">@item.Quantity @item.Unit</td>
                        <td>
                            @if (item.Quantity == 0)
                            {
                                <span class="status-badge status-out">Out</span>
                            }
                            else if (item.Quantity < 20)
                            {
                                <span class="status-badge status-low">Low</span>
                            }
                            else
                            {
                                <span class="status-badge status-fresh">Available</span>
                            }
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    }
    else
    {
        <div style="text-align: center; padding: 2rem;">
            <p style="font-size: 1.1rem; color: var(--text-secondary);">📭 No products in inventory yet</p>
        </div>
    }
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/%40microsoft/signalr@7.0.7/dist/browser/signalr.min.js"></script>
    <script>
        (function () {
            function toNumber(v) { return typeof v === 'number' ? v : (v ? Number(v) : 0); }

            function unitShort(unit) {
                return unit === 'Kilogram' || unit === 'Kilograms' ? 'kg'
                    : unit === 'Gram' || unit === 'Grams' ? 'g'
                    : unit === 'Pound' ? 'lbs'
                    : unit === 'Piece' ? 'pcs'
                    : unit;
            }

            function getStatusBadge(item) {
                var qty = toNumber(item.quantity ?? item.Quantity);
                if (qty === 0) return '<span class="status-badge status-out">Out</span>';
                if (qty < 20) return '<span class="status-badge status-low">Low</span>';
                return '<span class="status-badge status-fresh">Available</span>';
            }

            var connection = new signalR.HubConnectionBuilder()
                .withUrl('/inventoryHub')
                .withAutomaticReconnect()
                .build();

            connection.on('InventoryChanged', function (dashboard) {
                try {
                    var total = dashboard.totalItems ?? dashboard.TotalItems;
                    var fresh = dashboard.freshStock ?? dashboard.FreshStock;
                    var low = dashboard.lowStockItems ?? dashboard.LowStockItems;
                    var spoiled = dashboard.spoiledItems ?? dashboard.SpoiledItems;
                    var recent = dashboard.recentItems ?? dashboard.RecentItems ?? [];

                    var elTotal = document.getElementById('totalItems');
                    var elFresh = document.getElementById('freshStock');
                    var elLow = document.getElementById('lowStock');
                    var elSpoiled = document.getElementById('spoiledItems');
                    var tbody = document.getElementById('recentItemsTbody');

                    if (elTotal) elTotal.innerHTML = '<span>' + (total ?? '0') + '</span><span class="metric-icon">📦</span>';
                    if (elFresh) elFresh.innerHTML = '<span>' + (Math.round((fresh ?? 0) * 100) / 100) + '</span><span class="metric-icon">📊</span>';
                    if (elLow) elLow.innerHTML = '<span>' + (low ?? '0') + '</span><span class="metric-icon">⚠️</span>';
                    if (elSpoiled) elSpoiled.innerHTML = '<span>' + (spoiled ?? '0') + '</span><span class="metric-icon">🚫</span>';

                    if (tbody) {
                        tbody.innerHTML = '';
                        recent.forEach(function (item) {
                            var qty = item.quantity ?? item.Quantity;
                            var unit = item.unit ?? item.Unit ?? '';
                            var tr = document.createElement('tr');
                            tr.innerHTML = '<td>' + (item.name ?? item.Name) + '</td>' +
                                '<td>' + (item.category ?? item.Category) + '</td>' +
                                '<td>' + qty + ' ' + unitShort(unit) + '</td>' +
                                '<td>' + getStatusBadge(item) + '</td>';
                            tbody.appendChild(tr);
                        });
                    }
                }
                catch (e) {
                    console.error('Error applying dashboard update', e);
                }
            });

            connection.start().catch(function (err) { console.error(err.toString()); });
        })();
    </script>
}
