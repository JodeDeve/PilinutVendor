@model PilinutVendorSystem.Models.InventoryItem
@{
    ViewData["Title"] = "Item details";

    string GetUnitShortName(PilinutVendorSystem.Models.UnitType unit)
    {
        return unit switch
        {
            PilinutVendorSystem.Models.UnitType.Kilogram => "kg",
            PilinutVendorSystem.Models.UnitType.Gram => "g",
            PilinutVendorSystem.Models.UnitType.Pound => "lbs",
            PilinutVendorSystem.Models.UnitType.Piece => "pcs",
            _ => ""
        };
    }
}

<div style="max-width: 900px; margin: 0 auto;">
    <!-- Page Header -->
    <div class="page-header" style="margin-bottom: 2.5rem;">
        <h1 class="page-title" style="font-size: 2rem;"> Product Details</h1>
        <p class="page-subtitle">Review the selected product information</p>
    </div>

    <!-- Details Container -->
    <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 2rem;">
        <!-- Product Image Section -->
        <div>
            <div style="background: var(--bg-secondary); border-radius: var(--radius); padding: 1.5rem; box-shadow: var(--shadow-sm); border: 1px solid var(--border-color); overflow: hidden; min-height: 300px; display: flex; align-items: center; justify-content: center;">
                <img src="@Model.GetImagePath()" alt="@Model.Name" style="width: 100%; height: auto; border-radius: 0.5rem; object-fit: cover; max-height: 350px;" onerror="this.style.display='none'; this.parentElement.innerHTML='<span style=\"font-size:5rem;\ />
            </div>
        </div>

        <!-- Product Info Section -->
        <div>
            <div style="background: var(--bg-secondary); border-radius: var(--radius); padding: 2rem; box-shadow: var(--shadow-sm); border: 1px solid var(--border-color);">
                <h2 style="font-size: 1.75rem; font-weight: 700; margin-bottom: 1rem; color: var(--text-primary);">@Model.Name</h2>

                <!-- Details List -->
                <div style="margin-bottom: 2rem;">
                    <div style="display: flex; justify-content: space-between; padding: 1rem; border-bottom: 1px solid var(--border-color); align-items: center;">
                        <span style="font-weight: 600; color: var(--text-primary);"> Category</span>
                        <span style="color: var(--text-secondary);">@Model.Category</span>
                    </div>

                    <div style="display: flex; justify-content: space-between; padding: 1rem; border-bottom: 1px solid var(--border-color); align-items: center;">
                        <span style="font-weight: 600; color: var(--text-primary);"> Stock Level</span>
                        <span style="color: var(--text-secondary); font-size: 1.1rem;">@Model.Quantity @GetUnitShortName(Model.Unit)</span>
                    </div>

                    <div style="display: flex; justify-content: space-between; padding: 1rem; border-bottom: 1px solid var(--border-color); align-items: center;">
                        <span style="font-weight: 600; color: var(--text-primary);"> Unit Price</span>
                        <span style="color: var(--primary); font-size: 1.3rem; font-weight: 700;">₱@Model.Price.ToString("N2")</span>
                    </div>

                    <!-- Stock Status -->
                    <div style="display: flex; justify-content: space-between; padding: 1rem; align-items: center;">
                        <span style="font-weight: 600; color: var(--text-primary);"> Status</span>
                        <div>
                            @if (Model.Quantity == 0)
                            {
                                <span class="status-badge status-out">Out of Stock</span>
                            }
                            else if (Model.Quantity < 20)
                            {
                                <span class="status-badge status-low">Low Stock</span>
                            }
                            else
                            {
                                <span class="status-badge status-fresh">In Stock</span>
                            }
                        </div>
                    </div>
                </div>

                <!-- Action Buttons -->
                <div style="display: flex; gap: 1rem; padding-top: 1.5rem; border-top: 1px solid var(--border-color);">
                    <a asp-action="Edit" asp-route-id="@Model.Id" 
                       style="flex: 1; padding: 0.875rem 1.5rem; background: linear-gradient(135deg, var(--primary) 0%, var(--primary-dark) 100%); color: white; border: none; border-radius: 0.5rem; font-weight: 600; cursor: pointer; transition: all 0.3s ease; font-size: 1rem; box-shadow: var(--shadow-sm); text-align: center; text-decoration: none; display: flex; align-items: center; justify-content: center;">
                        ✎ Edit Item
                    </a>
                    <a asp-action="Index" 
                       style="flex: 1; padding: 0.875rem 1.5rem; background: var(--bg-primary); border: 1.5px solid var(--border-color); color: var(--text-primary); text-align: center; display: flex; align-items: center; justify-content: center; text-decoration: none; border-radius: 0.5rem; font-weight: 600; transition: all 0.3s ease; cursor: pointer;">
                        ← Back to Inventory
                    </a>
                </div>
            </div>
        </div>
    </div>
</div>
