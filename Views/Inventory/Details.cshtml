@model PilinutVendorSystem.Models.InventoryItem
@{
    ViewData["Title"] = "Item details";

    string GetUnitShortName(PilinutVendorSystem.Models.UnitType unit)
    {
        return unit switch
        {
            PilinutVendorSystem.Models.UnitType.Kilogram => "kg",
            PilinutVendorSystem.Models.UnitType.Gram => "g",
            PilinutVendorSystem.Models.UnitType.Pound => "lbs",
            PilinutVendorSystem.Models.UnitType.Piece => "pcs",
            _ => ""
        };
    }
}

<div class="page-header mb-4">
    <div>
        <p class="eyebrow">Inventory details</p>
        <h1>@Model.Name</h1>
        <p class="text-muted">Review the selected product information.</p>
    </div>
    <a asp-action="Index" class="btn btn-outline-secondary">Back to inventory</a>
</div>

<div class="card card-panel">
    <div class="card-body">
        <div class="row gx-4 gy-4">
            <div class="col-md-6">
                @if (!string.IsNullOrEmpty(Model.ImagePath))
                {
                    <div class="mb-4">
                        <img src="@Model.ImagePath" alt="@Model.Name" class="img-fluid rounded" style="max-width: 100%; max-height: 400px; object-fit: cover;" />
                    </div>
                }
                <h5 class="mb-3">Item summary</h5>
                <dl class="detail-list">
                    <dt>Category</dt>
                    <dd><span class="badge badge-category badge-category-@Model.Category">@Model.Category</span></dd>

                    <dt>Quantity</dt>
                    <dd>@Model.Quantity @GetUnitShortName(Model.Unit)</dd>

                    <dt>Price per unit</dt>
                    <dd>₱ @Model.Price.ToString("N2")</dd>
                </dl>
            </div>
            <div class="col-md-6">
                <div class="detail-panel">
                    <h6>Actions</h6>
                    <p class="text-muted">Update stock, pricing, or upload a new photo.</p>
                    <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-primary">Edit item</a>
                </div>
            </div>
        </div>
    </div>
</div>
