@model PilinutVendorSystem.Models.InventoryItem
@{
    ViewData["Title"] = "Edit item";
}

<div class="page-header mb-4">
    <div>
        <p class="eyebrow">Edit inventory item</p>
        <h1>Update product</h1>
        <p class="text-muted">Adjust quantity, price, or category.</p>
    </div>
    <a asp-action="Index" class="btn btn-outline-secondary">Back to inventory</a>
</div>

<div class="card card-panel">
    <div class="card-body">
        <form asp-action="Edit" method="post" enctype="multipart/form-data">
            <input type="hidden" asp-for="Id" />
            <div asp-validation-summary="ModelOnly" class="validation-summary"></div>

            <div class="row gy-3">
                <div class="col-md-6">
                    <label asp-for="Name" class="form-label"></label>
                    <input asp-for="Name" class="form-control form-control-lg" />
                    <span asp-validation-for="Name" class="text-danger"></span>
                </div>

                <div class="col-md-6">
                    <label asp-for="Category" class="form-label"></label>
                    <select asp-for="Category" class="form-select form-select-lg" asp-items="Html.GetEnumSelectList<PilinutVendorSystem.Models.CategoryType>()"></select>
                    <span asp-validation-for="Category" class="text-danger"></span>
                </div>

                <div class="col-md-6">
                    <label asp-for="Quantity" class="form-label"></label>
                    <input asp-for="Quantity" type="number" step="0.01" class="form-control form-control-lg" />
                    <span asp-validation-for="Quantity" class="text-danger"></span>
                </div>

                <div class="col-md-6">
                    <label asp-for="Unit" class="form-label"></label>
                    <select asp-for="Unit" class="form-select form-select-lg" asp-items="Html.GetEnumSelectList<PilinutVendorSystem.Models.UnitType>()"></select>
                    <span asp-validation-for="Unit" class="text-danger"></span>
                </div>

                <div class="col-md-6">
                    <label asp-for="Price" class="form-label"></label>
                    <input asp-for="Price" type="number" step="0.01" class="form-control form-control-lg" placeholder="e.g., 250" />
                    <small class="text-muted">Price in Philippine Pesos (PHP)</small>
                    <span asp-validation-for="Price" class="text-danger"></span>
                </div>

                @if (!string.IsNullOrEmpty(Model.ImagePath))
                {
                    <div class="col-md-12">
                        <div class="image-preview mb-2">
                            <img src="@Model.ImagePath" alt="@Model.Name" class="img-thumbnail" style="max-width: 200px; max-height: 200px; object-fit: cover;" />
                        </div>
                    </div>
                }

                <div class="col-md-12">
                    <label for="imageFile" class="form-label">Update product photo</label>
                    <input type="file" id="imageFile" name="imageFile" class="form-control form-control-lg" accept="image/*" />
                    <small class="text-muted">JPG, PNG, GIF or WebP (optional)</small>
                </div>
            </div>

            <div class="mt-4">
                <button type="submit" class="btn btn-primary btn-lg me-2">Save changes</button>
                <a asp-action="Index" class="btn btn-outline-secondary btn-lg">Cancel</a>
            </div>
        </form>
    </div>
</div>
